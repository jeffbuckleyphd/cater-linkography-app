spatial =~ visual.perception + cubes + lozenges
verbal =~ paragraph.comprehension + sentence.completion + word.meaning
speed = ~ speeded.addition + speeded.counting + speeded.discrimination
'
fit_model <- lavaan(model = model_1,
data = mydata,
auto.var=TRUE,
auto.fix.first=TRUE,
auto.cov.lv.x=TRUE)
summary(fit_model,
standardized = TRUE,
fit.measures = TRUE)
lavaanPlot(model = fit_model,
stand = TRUE,
coefs = TRUE,
stars = c("regress", "latent"),
node_options = list(shape = "box", fontname = "Helvetica", color = "grey"),
edge_options = list(color = "black"))

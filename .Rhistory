library(performance)
mydata <- HolzingerSwineford1939
### Data cleaning
## Rename variables
mydata <- mydata %>%
rename(age.year = ageyr,
age.month = agemo,
visual.perception = x1,
cubes = x2,
lozenges = x3,
paragraph.comprehension = x4,
sentence.completion = x5,
word.meaning = x6,
speeded.addition = x7,
speeded.counting = x8,
speeded.discrimination = x9)
View(mydata)
library(lavaanPlot)
model_1 <- '
spatial =~ visual.processing + cubes + lozenges
verbal =~ paragraph.comprehension + sentence.completion + word.meaning
speed = ~ speeded.addition + speeded.counting + speeded.discrimination
'
fit_model <- lavaan(model = model_1,
data = mydata,
auto.var=TRUE,
auto.fix.first=TRUE,
auto.cov.lv.x=TRUE)
View(mydata)
